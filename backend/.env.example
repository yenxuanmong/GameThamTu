# ============================================
# Detective Royale — Environment Variables
# Copy this file to .env and fill in the values
# ============================================

# App
NODE_ENV=production
PORT=3000
APP_NAME="Detective Royale"
APP_VERSION=0.1.0
FRONTEND_URL=https://your-frontend-url.com

# Database (PostgreSQL) — Railway provides this automatically
DATABASE_URL=postgresql://postgres:password@host:5432/railway

# Redis — Railway provides this automatically
REDIS_URL=redis://default:password@host:6379

# JWT — Generate strong random secrets for production!
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_refresh_secret_too
JWT_REFRESH_EXPIRES_IN=30d

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.8

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Game Settings
MAX_PLAYERS_PER_ROOM=4
MATCH_DURATION_SECONDS=1800
MIN_PLAYERS_TO_START=2
MATCHMAKING_TIMEOUT_SECONDS=60

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log
