%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_Script: {fileID: 11500000, guid: volume_profile_guid, type: 3}
  m_Name: PostProcessVolume_Results
  m_EditorClassIdentifier: 
  components:
  # Bloom — celebratory
  - m_Active: 1
    threshold:
      m_OverrideState: 1
      m_Value: 0.85
    intensity:
      m_OverrideState: 1
      m_Value: 0.6
    scatter:
      m_OverrideState: 1
      m_Value: 0.8
    tint:
      m_OverrideState: 1
      m_Value: {r: 1, g: 0.95, b: 0.7, a: 1}
  # Color Adjustments — warm, saturated win screen
  - m_Active: 1
    postExposure:
      m_OverrideState: 1
      m_Value: 0.1
    contrast:
      m_OverrideState: 1
      m_Value: 5
    colorFilter:
      m_OverrideState: 1
      m_Value: {r: 1, g: 0.97, b: 0.88, a: 1}
    saturation:
      m_OverrideState: 1
      m_Value: 10
